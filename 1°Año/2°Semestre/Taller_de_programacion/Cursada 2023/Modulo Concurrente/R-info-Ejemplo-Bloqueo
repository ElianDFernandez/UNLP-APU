programa practica
procesos 
  proceso juntar(ES flor:numero)
  comenzar 
    mientras(HayFlorEnLaEsquina)
      tomarFlor
      flor:=flor+1
  fin
  proceso rectangulo(E alto:numero; E ancho:numero; ES flores:numero)
  comenzar 
    flores:=0
    repetir 2 
      repetir alto
        juntar(flores)
        mover
      derecha
      repetir ancho
        juntar(flores)
        mover
      derecha
  fin 
