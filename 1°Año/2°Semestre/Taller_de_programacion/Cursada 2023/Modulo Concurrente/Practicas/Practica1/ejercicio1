programa p1e1
procesos 
  proceso juntarFlores(ES f:numero)
  comenzar
    mientras(HayFlorEnLaEsquina)
      tomarFlor
      f:=f+1
  fin 
areas
  ciudad:AreaC(1,1,100,100)
robots
  robot tipo1
  variables
    f:numero
    esqSinFlor:numero
  comenzar      
    esqSinFlor:=0
    f:=0
    si (HayFlorEnLaEsquina) 
      juntarFlores(f)
    sino
      esqSinFlor:=esqSinFlor + 1
    repetir 99
      mover 
      si (HayFlorEnLaEsquina)
        juntarFlores(f)
      sino
        esqSinFlor:=esqSinFlor + 1 
    Informar(f)
    Informar(esqSinFlor)
  fin
variables
  robot1:tipo1
  robot2:tipo1
  robot3:tipo1
comenzar 
  AsignarArea(robot1,ciudad)
  AsignarArea(robot2,ciudad)
  AsignarArea(robot3,ciudad)
  Iniciar(robot1,1,1)
  Iniciar(robot2,3,1)
  Iniciar(robot3,5,1)
fin