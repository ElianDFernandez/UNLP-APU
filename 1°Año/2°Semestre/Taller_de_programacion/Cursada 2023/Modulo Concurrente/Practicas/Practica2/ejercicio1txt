programa p2eje1
procesos 
  proceso juntarFlores(ES f:numero)
  comenzar   
    mientras(HayFlorEnLaEsquina)
      tomarFlor
      f:=f+1
  fin
  proceso realizarRecorrido(ES f:numero)
  comenzar 
    f:=0
    repetir 10
      juntarFlores(f)
      mover
  fin
areas
  ciudad: AreaC(1,1,100,100)
robots
  robot competidor1
  variables
    f:numero
    comp:numero
  comenzar
    realizarRecorrido(f)
    EnviarMensaje(f,julieta)
    RecibirMensaje(comp,julieta)
    si comp < f 
      Informar(f)
  fin
  robot competidor2
  variables
    f:numero
    comp:numero
  comenzar
    realizarRecorrido(f)
    EnviarMensaje(f,elian)
    RecibirMensaje(comp,elian)
    si comp < f
      Informar(f)
  fin
variables
  elian:competidor1
  julieta:competidor2
comenzar
  AsignarArea(elian,ciudad)
  AsignarArea(julieta,ciudad)
  Iniciar(elian,1,1)
  Iniciar(julieta,2,11)
fin