programa practica
procesos 
  proceso juntar(ES flor:numero)
  comenzar 
    mientras(HayFlorEnLaEsquina)
      tomarFlor
      flor:=flor+1
  fin
  proceso rectangulo(E alto:numero; E ancho:numero; ES flores:numero)
  comenzar 
    flores:=0
    repetir 2 
      repetir alto
        juntar(flores)
        mover
      derecha
      repetir ancho
        juntar(flores)
        mover
      derecha
  fin 
areas 
  ciudad : AreaC(1,1,100,100)
robots
  robot jefe 
  variables 
    x:numero
    y:numero
    f:numero
    quien:numero
    max:numero
    rmax:numero
  comenzar 
    x:=7
    y:=10
    max:=0
    rmax:=0
    EnviarMensaje(1,robot1)
    EnviarMensaje(2,robot2)
    EnviarMensaje(5,robot1)
    EnviarMensaje(3,robot1)
    EnviarMensaje(x,robot2)
    EnviarMensaje(y,robot2)
    repetir 2
      RecibirMensaje(quien,*)
      si quien = 1
        RecibirMensaje(f,robot1)
      sino
        RecibirMensaje(f,robot2)
      si f >= max
        max:=f
        rmax:=quien
    Informar(rmax)
  fin
